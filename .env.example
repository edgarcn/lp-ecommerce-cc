# Copy this file to .env (docker compose reads .env automatically):
#   cp .env.example .env
#
# The values below are working DEMO defaults so the stack runs out of the box.
# Replace them with real secrets for any non-demo deployment.

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=root_pwd_2026
MYSQL_DATABASE=ecommerce_db
MYSQL_USER=ecommerce_user
MYSQL_PASSWORD=ecommerce_pwd_2026

# ----- Auth (API) -----
# JwtSecret must be at least 32 chars for HS256.
AUTH_JWT_SECRET=Z7rQm2vT9eK4pH1xS8uL5cN0wB3dF6gJ
AUTH_ADMIN_USERNAME=admin
# BCrypt hash for the admin password (work factor 11). See README to regenerate.
# IMPORTANT: each '$' is doubled to '$$' to escape docker compose interpolation;
# the container still receives the correct single-'$' hash.
AUTH_ADMIN_PASSWORD_HASH=$$2a$$11$$e4.7zodCmmA7S/geEpGWT.ZjMd54ekBxa8AcHsr4Esh0q8crr7.Xe

# ----- Web -----
# Origin the SPA is served from; added to the API CORS allow-list.
WEB_ORIGIN=http://localhost:8080
